---
interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  crumbs: Crumb[];
}
const { crumbs } = Astro.props;

const parent = crumbs.find(c => c.href);
---

<nav class="mb-10" aria-label="Breadcrumb">
  <!-- Móvil: solo muestra el link padre -->
  {parent && (
    <a
      href={parent.href}
      class="md:hidden inline-flex items-center gap-1.5 text-sm text-gray-400 hover:text-accent transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="m15 18-6-6 6-6"/>
      </svg>
      {parent.label}
    </a>
  )}

  <!-- Desktop: breadcrumb completo con título truncado -->
  <ol class="hidden md:flex items-center gap-1.5 text-sm text-gray-400 min-w-0">
    <li class="shrink-0">
      <a href="/" class="hover:text-accent transition-colors">Inicio</a>
    </li>
    {crumbs.map((crumb, i) => {
      const isLast = i === crumbs.length - 1;
      return (
        <li class={`flex items-center gap-1.5 ${isLast ? 'min-w-0 truncate' : 'shrink-0'}`}>
          <span>/</span>
          {crumb.href && !isLast
            ? <a href={crumb.href} class="hover:text-accent transition-colors">{crumb.label}</a>
            : <span class={`text-gray-600 dark:text-gray-300 ${isLast ? 'truncate block' : ''}`}>{crumb.label}</span>
          }
        </li>
      );
    })}
  </ol>
</nav>
