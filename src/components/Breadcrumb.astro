---
interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  crumbs: Crumb[];
}
const { crumbs } = Astro.props;
---

<nav class="flex items-center gap-1.5 text-sm text-gray-400 mb-10">
  <a href="/" class="hover:text-accent transition-colors">Inicio</a>
  {crumbs.map((crumb, i) => (
    <>
      <span>/</span>
      {crumb.href && i < crumbs.length - 1
        ? <a href={crumb.href} class="hover:text-accent transition-colors">{crumb.label}</a>
        : <span class="text-gray-600 dark:text-gray-300">{crumb.label}</span>
      }
    </>
  ))}
</nav>
