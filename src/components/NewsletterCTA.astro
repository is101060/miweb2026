---
const substackUrl = 'https://substack.com/@tu-usuario';
---

<div class="rounded-2xl border border-accent/20 bg-accent/5 dark:bg-accent/10 px-8 py-8 text-center">
  <p class="text-xs font-medium tracking-widest uppercase text-accent mb-3">Newsletter</p>
  <h3 class="font-serif text-2xl font-semibold text-gray-900 dark:text-gray-100 mb-3">
    Recibe mis artículos en tu correo
  </h3>
  <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed mb-6 max-w-sm mx-auto">
    Escribo sobre tecnología, diseño y cosas que aprendo. Sin spam, cuando tenga algo que valga la pena compartir.
  </p>
  <a
    href={substackUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-block bg-accent text-white text-sm font-medium px-6 py-2.5 rounded-full hover:opacity-90 transition-opacity"
  >
    Suscribirse en Substack →
  </a>
</div>
