---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página no encontrada — Hugo" description="Esta página no existe.">
  <div class="py-16 text-center">
    <p class="font-serif text-8xl font-semibold text-accent mb-6">404</p>
    <h1 class="font-serif text-3xl font-semibold text-gray-900 dark:text-gray-100 mb-4">
      Página no encontrada
    </h1>
    <p class="text-gray-500 dark:text-gray-400 mb-10 max-w-sm mx-auto">
      Esta página no existe o fue movida. Puede que la URL esté mal escrita.
    </p>
    <div class="flex justify-center gap-4 text-sm">
      <a href="/" class="bg-accent text-white px-5 py-2.5 rounded-full hover:opacity-90 transition-opacity font-medium">
        Ir al inicio
      </a>
      <a href="/articles" class="border border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-400 px-5 py-2.5 rounded-full hover:border-accent hover:text-accent transition-colors font-medium">
        Ver artículos
      </a>
    </div>
  </div>
</Layout>
