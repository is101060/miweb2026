---
import Layout from '../../../layouts/Layout.astro';
import CategoryBadge from '../../../components/CategoryBadge.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES } from '../../../content.config';
import type { Category } from '../../../content.config';

export async function getStaticPaths() {
  const allArticles = await getCollection('articles', ({ data }) => !data.draft);

  return CATEGORIES.map((category) => {
    const slug = category.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');
    const filtered = allArticles
      .filter((a) => a.data.category === category)
      .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

    return { params: { category: slug }, props: { category, articles: filtered } };
  });
}

const { category, articles } = Astro.props as { category: Category; articles: any[] };

const fmt = (date: Date) =>
  date.toLocaleDateString('es-MX', { month: 'short', year: 'numeric' });
---

<Layout title={`${category} — Hugo`}>
  <a href="/articles" class="text-sm text-gray-400 hover:text-accent transition-colors mb-10 inline-block">
    ← Todos los artículos
  </a>

  <div class="flex items-center gap-3 mb-6">
    <h1 class="font-serif text-3xl font-semibold text-gray-900 dark:text-gray-100">{category}</h1>
    <CategoryBadge category={category} />
  </div>
  <p class="text-sm text-gray-400 mb-10">{articles.length} {articles.length === 1 ? 'artículo' : 'artículos'}</p>

  <!-- Otras categorías -->
  <div class="flex gap-2 mb-10 flex-wrap">
    {CATEGORIES.filter((c) => c !== category).map((cat) => (
      <CategoryBadge category={cat} link />
    ))}
  </div>

  <ul class="space-y-2">
    {articles.map((a) => (
      <li class="border-b border-gray-100 dark:border-gray-800 last:border-0 py-4">
        <a href={`/articles/${a.id}`} class="flex items-center gap-4 group">
          <div class="shrink-0 w-16 h-16 rounded-lg overflow-hidden bg-gray-100 dark:bg-gray-800">
            {a.data.image
              ? <img src={a.data.image} alt={a.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
              : <div class="w-full h-full flex items-center justify-center text-gray-300 dark:text-gray-600 text-xl">✦</div>
            }
          </div>
          <div class="flex-1 min-w-0">
            <span class="text-xs text-gray-400 mb-1 block">{fmt(a.data.date)}</span>
            <p class="text-gray-800 dark:text-gray-200 group-hover:text-accent transition-colors font-medium truncate">
              {a.data.title}
            </p>
            <p class="text-sm text-gray-400 mt-0.5 truncate">{a.data.description}</p>
          </div>
        </a>
      </li>
    ))}
  </ul>
</Layout>
