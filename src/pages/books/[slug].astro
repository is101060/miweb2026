---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { books } from '../../data/books';

export async function getStaticPaths() {
  const reviews = await getCollection('bookReviews');
  return reviews.map((review) => ({
    params: { slug: review.data.slug },
    props: { review },
  }));
}

const { review } = Astro.props;
const { Content } = await render(review);

const book = books.find((b) => b.reviewSlug === review.data.slug);

const fmt = (date: Date) =>
  date.toLocaleDateString('es-MX', { day: 'numeric', month: 'long', year: 'numeric' });

const stars = Array.from({ length: 5 }, (_, i) => i < review.data.rating);
---

<Layout title={`${book?.title ?? 'Reseña'} — Hugo`} description={`Reseña de ${book?.title}`}>
  <a href="/books" class="text-sm text-gray-400 hover:text-accent transition-colors mb-12 inline-block">
    ← Mi Librero
  </a>

  <article>
    <header class="mb-10">
      <div class="flex gap-6 mb-6">
        {book?.cover && (
          <img
            src={book.cover}
            alt={`Portada de ${book.title}`}
            class="w-20 h-28 object-cover rounded shadow-md shrink-0"
          />
        )}
        <div class="flex flex-col justify-end">
          <p class="text-xs font-medium tracking-widest uppercase text-accent mb-2">Reseña</p>
          <h1 class="font-serif text-3xl font-semibold text-gray-900 dark:text-gray-100 leading-tight mb-1">
            {book?.title}
          </h1>
          <p class="text-gray-400 mb-3">{book?.author}</p>
          <div class="flex items-center gap-3">
            <div class="flex gap-0.5">
              {stars.map((filled) => (
                <span class={filled ? 'text-accent' : 'text-gray-200 dark:text-gray-700'}>★</span>
              ))}
            </div>
            <span class="text-sm text-gray-400">{fmt(review.data.date)}</span>
          </div>
        </div>
      </div>
      <div class="h-px bg-gradient-to-r from-accent/60 to-transparent"></div>
    </header>

    <div class="prose dark:prose-invert max-w-none
      prose-headings:font-serif prose-headings:font-semibold prose-headings:text-gray-900 dark:prose-headings:text-gray-100
      prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4
      prose-p:text-gray-700 dark:prose-p:text-gray-300 prose-p:leading-[1.85] prose-p:text-[1.05rem]
      prose-a:text-accent prose-a:no-underline hover:prose-a:underline
      prose-strong:text-gray-900 dark:prose-strong:text-gray-100
      prose-em:text-gray-700 dark:prose-em:text-gray-300">
      <Content />
    </div>
  </article>
</Layout>
