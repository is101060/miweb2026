---
import Layout from '../../layouts/Layout.astro';
import { books } from '../../data/books';

const byYear: Record<string, typeof books> = {};
for (const book of books) {
  const year = book.finishedDate.split('-')[0];
  if (!byYear[year]) byYear[year] = [];
  byYear[year].push(book);
}

const years = Object.keys(byYear).sort((a, b) => Number(b) - Number(a));

const fmtMonth = (ym: string) => {
  const [year, month] = ym.split('-');
  return new Date(Number(year), Number(month) - 1).toLocaleDateString('es-MX', { month: 'long' });
};

const total = books.filter(b => b.status === 'leído').length;
---

<Layout title="Mi Librero — Hugo">
  <div class="flex items-end justify-between mb-3">
    <h1 class="font-serif text-3xl font-semibold text-gray-900 dark:text-gray-100">Mi Librero</h1>
    <span class="text-sm text-gray-400">{total} libros leídos</span>
  </div>
  <p class="text-gray-500 dark:text-gray-400 mb-12">Libros que he leído desde enero 2026.</p>

  {years.map((year) => (
    <section class="mb-12">
      <h2 class="font-serif text-xl font-semibold text-gray-900 dark:text-gray-100 mb-6">{year}</h2>
      <ul class="space-y-6">
        {byYear[year].map((book) => (
          <li class="flex gap-4 pb-6 border-b border-gray-100 dark:border-gray-800 last:border-0">
            <div class="shrink-0">
              {book.cover ? (
                <img
                  src={book.cover}
                  alt={`Portada de ${book.title}`}
                  class="w-14 h-20 object-cover rounded shadow-sm"
                />
              ) : (
                <div class="w-14 h-20 rounded bg-gray-100 dark:bg-gray-800 flex items-center justify-center">
                  <span class="text-gray-300 dark:text-gray-600 text-xl">📖</span>
                </div>
              )}
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-start justify-between gap-2">
                <div>
                  <p class="font-medium text-gray-900 dark:text-gray-100">{book.title}</p>
                  <p class="text-sm text-gray-400 mt-0.5">{book.author}</p>
                </div>
                {book.status === 'leyendo' && (
                  <span class="text-xs font-medium px-2.5 py-1 rounded-full shrink-0 bg-blue-50 text-blue-700 dark:bg-blue-950 dark:text-blue-300">
                    leyendo
                  </span>
                )}
              </div>
              {book.notes && (
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-2 italic">"{book.notes}"</p>
              )}
              <div class="flex items-center gap-4 mt-2">
                {book.status === 'leído' && (
                  <p class="text-xs text-gray-400 capitalize">{fmtMonth(book.finishedDate)}</p>
                )}
                {book.reviewSlug && (
                  <a href={`/books/${book.reviewSlug}`} class="text-xs text-accent hover:underline font-medium">
                    Leer reseña →
                  </a>
                )}
              </div>
            </div>
          </li>
        ))}
      </ul>
    </section>
  ))}
</Layout>
