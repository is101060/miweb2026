---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';

const editions = (await getCollection('ideas'))
  .sort((a, b) => b.data.number - a.data.number);

const fmt = (date: Date) =>
  date.toLocaleDateString('es-MX', { day: 'numeric', month: 'long', year: 'numeric' });
---

<Layout title="5 ideas — Hugo" description="Cada semana, cinco cosas que encontré interesantes.">
  <Breadcrumb crumbs={[{ label: '5 ideas' }]} />

  <header class="mb-10">
    <h1 class="font-serif text-4xl font-semibold mb-3 text-gray-900 dark:text-gray-100">5 ideas</h1>
    <p class="text-gray-500 dark:text-gray-400 text-lg leading-relaxed">
      Cada semana, cinco cosas que encontré interesantes: ideas, artículos, videos, herramientas o libros.
    </p>
    <div class="mt-6 h-px bg-gradient-to-r from-accent/60 to-transparent"></div>
  </header>

  <ul class="divide-y divide-gray-100 dark:divide-gray-800">
    {editions.map((e) => (
      <li>
        <a href={`/ideas/${e.id}`} class="group flex items-center gap-6 py-6 hover:opacity-80 transition-opacity">
          <div class="shrink-0 w-16 text-right">
            <span class="font-serif text-4xl font-semibold text-accent leading-none">#{e.data.number}</span>
          </div>
          <div class="flex-1 min-w-0">
            <time class="text-xs text-gray-400 block mb-1">{fmt(e.data.date)}</time>
            <p class="text-gray-800 dark:text-gray-200 leading-relaxed group-hover:text-accent transition-colors">
              {e.data.description}
            </p>
          </div>
          <svg class="shrink-0 text-gray-300 dark:text-gray-700 group-hover:text-accent transition-colors" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m9 18 6-6-6-6"/>
          </svg>
        </a>
      </li>
    ))}
  </ul>
</Layout>
