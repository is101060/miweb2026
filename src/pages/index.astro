---
import Layout from '../layouts/Layout.astro';
import NewsletterCTA from '../components/NewsletterCTA.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const stories = (await getCollection('stories', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const projects = [
  {
    name: 'Proyecto uno',
    description: 'Descripción del proyecto. Qué hace, qué problema resuelve.',
    url: '#',
    tag: 'Web',
    emoji: '🌐',
    color: 'bg-blue-50 text-blue-700 dark:bg-blue-950 dark:text-blue-300',
  },
  {
    name: 'Proyecto dos',
    description: 'Descripción del proyecto. Qué hace, qué problema resuelve.',
    url: '#',
    tag: 'CLI',
    emoji: '⚡',
    color: 'bg-yellow-50 text-yellow-700 dark:bg-yellow-950 dark:text-yellow-300',
  },
  {
    name: 'Proyecto tres',
    description: 'Descripción del proyecto. Qué hace, qué problema resuelve.',
    url: '#',
    tag: 'API',
    emoji: '🔌',
    color: 'bg-purple-50 text-purple-700 dark:bg-purple-950 dark:text-purple-300',
  },
  {
    name: 'Proyecto cuatro',
    description: 'Descripción del proyecto. Qué hace, qué problema resuelve.',
    url: '#',
    tag: 'Open source',
    emoji: '🛠️',
    color: 'bg-emerald-50 text-emerald-700 dark:bg-emerald-950 dark:text-emerald-300',
  },
];

const fmt = (date: Date) =>
  date.toLocaleDateString('es-MX', { month: 'short', year: 'numeric' });
---

<Layout title="Hugo" description="Sitio personal de Hugo">

  <!-- Hero -->
  <section class="py-16 mb-4">
    <h1 class="font-serif text-6xl font-semibold mb-5 text-gray-900 dark:text-gray-100 leading-tight">Hugo</h1>
    <p class="text-gray-500 dark:text-gray-400 text-xl leading-relaxed max-w-xl mb-7">
      Escribo sobre tecnología, diseño y software. Aquí comparto proyectos en los que trabajo y artículos sobre lo que aprendo.
    </p>
    <div class="flex gap-5 text-sm">
      <a href="https://linkedin.com/in/tu-usuario" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-accent transition-colors">LinkedIn</a>
      <a href="https://instagram.com/tu-usuario" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-accent transition-colors">Instagram</a>
      <a href="https://substack.com/@tu-usuario" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-accent transition-colors">Substack</a>
    </div>
  </section>

  <!-- Artículos: lista con thumbnail -->
  <section class="mb-20">
    <div class="flex items-center gap-3 mb-8">
      <div class="w-1 h-6 bg-accent rounded-full"></div>
      <h2 class="font-serif text-2xl font-semibold text-gray-900 dark:text-gray-100">Artículos recientes</h2>
      <a href="/articles" class="text-sm text-accent hover:underline ml-auto">Ver todos →</a>
    </div>
    <ul class="space-y-1">
      {articles.map((a) => (
        <li class="border-b border-gray-100 dark:border-gray-800 last:border-0 py-3">
          <a href={`/articles/${a.id}`} class="flex items-center gap-4 group">
            <div class="shrink-0 w-14 h-14 rounded-lg overflow-hidden bg-gray-100 dark:bg-gray-800">
              {a.data.image
                ? <img src={a.data.image} alt={a.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                : <div class="w-full h-full flex items-center justify-center text-gray-300 dark:text-gray-600">✦</div>
              }
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-gray-800 dark:text-gray-200 group-hover:text-accent transition-colors font-medium leading-snug line-clamp-2">
                {a.data.title}
              </p>
              <span class="text-xs text-gray-400 mt-1 block">{fmt(a.data.date)}</span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <!-- Proyectos: grid -->
  <section class="mb-20">
    <div class="flex items-center gap-3 mb-8">
      <div class="w-1 h-6 bg-accent rounded-full"></div>
      <h2 class="font-serif text-2xl font-semibold text-gray-900 dark:text-gray-100">Proyectos</h2>
      <a href="/projects" class="text-sm text-accent hover:underline ml-auto">Ver todos →</a>
    </div>
    <ul class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      {projects.map((p) => (
        <li class="border border-gray-200 dark:border-gray-800 rounded-xl p-5 hover:border-accent dark:hover:border-accent hover:shadow-sm transition-all">
          <a href={p.url} class="block h-full">
            <div class="flex items-start justify-between mb-3">
              <span class="text-2xl">{p.emoji}</span>
              <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${p.color}`}>{p.tag}</span>
            </div>
            <h3 class="font-semibold text-gray-900 dark:text-gray-100 mb-1">{p.name}</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed mb-4">{p.description}</p>
            <span class="text-xs text-accent font-medium">Ver proyecto →</span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <!-- Historias: tarjetas -->
  <section class="mb-20">
    <div class="flex items-center gap-3 mb-8">
      <div class="w-1 h-6 bg-accent rounded-full"></div>
      <h2 class="font-serif text-2xl font-semibold text-gray-900 dark:text-gray-100">Mis Historias</h2>
      <a href="/stories" class="text-sm text-accent hover:underline ml-auto">Ver todas →</a>
    </div>
    <ul class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      {stories.map((s) => (
        <li class="border border-gray-200 dark:border-gray-800 rounded-xl overflow-hidden hover:border-accent dark:hover:border-accent hover:shadow-sm transition-all">
          <a href={`/stories/${s.id}`} class="block group">
            <div class="h-36 overflow-hidden bg-gray-100 dark:bg-gray-800">
              {s.data.image
                ? <img src={s.data.image} alt={s.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                : <div class="w-full h-full flex items-center justify-center text-gray-300 dark:text-gray-600 text-3xl">✦</div>
              }
            </div>
            <div class="p-4">
              <span class="text-xs text-gray-400 mb-1 block">{fmt(s.data.date)}</span>
              <h3 class="font-medium text-gray-900 dark:text-gray-100 group-hover:text-accent transition-colors leading-snug">
                {s.data.title}
              </h3>
              <p class="text-sm text-gray-400 mt-1 line-clamp-2">{s.data.description}</p>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <NewsletterCTA />
</Layout>
